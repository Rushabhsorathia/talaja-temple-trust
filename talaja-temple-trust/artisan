#!/usr/bin/env php
<?php

use Symfony\Component\Console\Input\ArgvInput;

define('LARAVEL_START', microtime(true));

// See public/index.php: silence PHP 8.5 deprecation notices (e.g. the
// PDO::MYSQL_ATTR_* constants in config/database.php) so they don't pollute
// command output. They fire before Laravel installs its exception handler.
error_reporting(error_reporting() & ~E_DEPRECATED & ~E_USER_DEPRECATED);

// Register the Composer autoloader...
require __DIR__.'/vendor/autoload.php';

// Bootstrap Laravel and handle the command...
$status = (require_once __DIR__.'/bootstrap/app.php')
    ->handleCommand(new ArgvInput);

exit($status);
